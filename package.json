{
  "name": "cakezake-pos",
  "version": "0.1.0",
  "private": true,
  "description": "CakeZake POS — scalable restaurant point-of-sale platform",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter api build && pnpm --filter web build",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:seed": "pnpm --filter api prisma:seed",
    "db:studio": "pnpm --filter api prisma:studio"
  },
  "engines": {
    "node": ">=20"
  }
}
