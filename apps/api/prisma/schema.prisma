// CakeZake POS — database schema
// Provider: PostgreSQL. ORM: Prisma.
// This schema models the full POS domain. In this first pass the API + UI
// fully implement Categories, MenuItems and Modifiers; the remaining models
// (Tables, Orders, KOT, Payments) are defined here so features can be added
// incrementally without breaking migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// MENU
// ─────────────────────────────────────────────────────────────

model Category {
  id        String     @id @default(cuid())
  name      String
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  // Price stored in minor units (cents) to avoid floating point errors.
  // priceCents is the base (dine-in) price; the tier prices below are
  // optional overrides used for takeaway / delivery (matrix #15).
  priceCents          Int
  takeawayPriceCents  Int?
  deliveryPriceCents  Int?
  // Which prep station this item routes to (KOT/BOT/Billing) (user workflow).
  station     PrepStation @default(BILLING)
  isAvailable Boolean  @default(true)
  imageUrl    String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Modifier groups attached to this item (e.g. "Size", "Add-ons").
  modifierGroups ModifierGroup[] @relation("MenuItemModifierGroups")

  orderItems OrderItem[]
  recipe     RecipeItem[] // BOM: ingredients this item consumes (matrix #57)
  variants   MenuItemVariant[] // portions e.g. Whiskey 30ml / 60ml

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@map("menu_items")
}

// A priced portion/variant of a menu item (replaces the base price when chosen).
model MenuItemVariant {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name       String   // e.g. "30ml", "Large"
  priceCents Int
  sortOrder  Int      @default(0)

  @@index([menuItemId])
  @@map("menu_item_variants")
}

model ModifierGroup {
  id          String     @id @default(cuid())
  name        String     // e.g. "Size", "Extra toppings"
  // Selection rules: how many options a customer may pick.
  minSelect   Int        @default(0)
  maxSelect   Int        @default(1)
  sortOrder   Int        @default(0)
  modifiers   Modifier[]
  menuItems   MenuItem[] @relation("MenuItemModifierGroups")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("modifier_groups")
}

model Modifier {
  id            String        @id @default(cuid())
  name          String        // e.g. "Large", "Extra cheese"
  priceCents    Int           @default(0) // price delta this modifier adds
  sortOrder     Int           @default(0)
  groupId       String
  group         ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([groupId])
  @@map("modifiers")
}

// ─────────────────────────────────────────────────────────────
// FLOOR / TABLES
// ─────────────────────────────────────────────────────────────

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

model RestaurantTable {
  id        String      @id @default(cuid())
  name      String      // e.g. "T1", "Patio 3"
  seats     Int         @default(4)
  area      String?     // e.g. "Ground floor", "Patio"
  status    TableStatus @default(AVAILABLE)
  isVip     Boolean     @default(false) // VIP / regulars highlighting (#39)
  // Floor-plan canvas position within its area (matrix #26).
  posX      Int?
  posY      Int?
  orders    Order[]
  reservations Reservation[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("restaurant_tables")
}

// ─────────────────────────────────────────────────────────────
// RESERVATIONS & WAITLIST (matrix #30)
// ─────────────────────────────────────────────────────────────

enum ReservationStatus {
  BOOKED
  SEATED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id           String            @id @default(cuid())
  customerName String
  phone        String?
  partySize    Int               @default(2)
  reservedAt   DateTime          // requested date/time (≈ now for waitlist)
  isWaitlist   Boolean           @default(false) // walk-in queue vs advance booking
  status       ReservationStatus @default(BOOKED)
  notes        String?

  tableId String?
  table   RestaurantTable? @relation(fields: [tableId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reservedAt])
  @@index([status])
  @@map("reservations")
}

// ─────────────────────────────────────────────────────────────
// ORDERS / KOT / BILLING
// ─────────────────────────────────────────────────────────────

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  OPEN
  SENT_TO_KITCHEN
  READY
  SERVED
  BILLED
  PAID
  REFUNDED
  CANCELLED
}

enum KotStatus {
  PENDING
  PREPARING
  READY
  SERVED
}

// Prep station an item routes to: kitchen (KOT), bar (BOT), or bill-only.
enum PrepStation {
  KITCHEN
  BAR
  BILLING
}

model Order {
  id         String      @id @default(cuid())
  // Human-friendly running order number.
  number     Int         @default(autoincrement())
  type       OrderType   @default(DINE_IN)
  status     OrderStatus @default(OPEN)

  tableId String?
  table   RestaurantTable? @relation(fields: [tableId], references: [id])

  waiterId String?
  waiter   Waiter? @relation(fields: [waiterId], references: [id])

  // Dine-in guest count (covers) — used for guest-time / per-cover analytics.
  guestCount Int @default(1)

  // Customer capture for takeaway / delivery (design spec §2.1 Step 2).
  customerName  String?
  customerPhone String?
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])

  items     OrderItem[]
  payments  Payment[]

  // Denormalised money snapshots (minor units).
  subtotalCents      Int @default(0)
  discountCents      Int @default(0)
  serviceChargeCents Int @default(0)
  taxCents           Int @default(0)
  totalCents         Int @default(0)

  notes     String?

  // Loyalty points redeemed against this order (#111).
  redeemedPoints Int @default(0)

  // Nepali fiscal year (e.g. "2082/83") + IRD-compliant invoice number that
  // resets each fiscal year — both stamped at payment time.
  fiscalYear      String?
  fiscalInvoiceNo Int?

  // IRD (CBMS) e-billing sync state for this invoice.
  irdSyncedAt   DateTime?
  irdSyncStatus String?   // SYNCED | FAILED
  irdSyncMessage String?

  // Which terminal/till rang this order (multi-terminal attribution).
  terminalId String?

  // Void / refund audit trail (matrix #10).
  voidReason   String?
  refundReason String?
  refundCents  Int       @default(0)
  refundedAt   DateTime?

  // Discount provenance — which named preset (Settings → Discounts) or
  // "Custom" was applied, and whether the whole bill was comped to zero.
  discountLabel   String?
  isComplimentary Boolean @default(false)

  // Lifecycle timestamps drive turnaround / guest-time metrics.
  seatedAt  DateTime?  // when the table became occupied for this order
  kotFiredAt DateTime? // when the KOT was first sent to the kitchen (KDS timer)
  billedAt  DateTime?
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([tableId])
  @@index([fiscalYear])
  @@map("orders")
}

model Waiter {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("waiters")
}

// ─────────────────────────────────────────────────────────────
// EMPLOYEES, ROLES & SHIFTS (matrix #126–140, spec §2.1/§3.1 Step 3)
// ─────────────────────────────────────────────────────────────

enum StaffRole {
  ADMIN
  MANAGER
  CASHIER
  BARISTA
  WAITER
}

model Employee {
  id           String    @id @default(cuid())
  name         String
  role         StaffRole @default(CASHIER)
  username     String?   @unique // username + password login
  passwordHash String?   // scrypt salt:hash
  isActive     Boolean   @default(true)
  // ZKTeco fingerprint device user ID (maps scans → this employee).
  deviceUserId String?   @unique
  // Payroll: fixed monthly salary in paisa (pro-rated by attendance).
  monthlySalaryCents Int @default(0)
  attendance   AttendanceLog[]

  // Granular permission matrix (#129, spec §3.1 Step 3).
  canVoid            Boolean @default(false)
  canDiscount        Boolean @default(false)
  canManageInventory Boolean @default(false)
  canViewReports     Boolean @default(false)
  canManageStaff     Boolean @default(false)

  shifts    Shift[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model Shift {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clockIn    DateTime  @default(now())
  clockOut   DateTime?

  @@index([employeeId])
  @@map("shifts")
}

// ─────────────────────────────────────────────────────────────
// CRM & LOYALTY (matrix #111–125)
// ─────────────────────────────────────────────────────────────

model Customer {
  id              String    @id @default(cuid())
  name            String
  phone           String    @unique
  email           String?
  birthday        DateTime?
  loyaltyPoints   Int       @default(0)
  totalSpentCents Int       @default(0)
  // Membership number (e.g. RADH1 — initials + sequence), PAN for businesses.
  memberCode      String?   @unique
  panNumber       String?
  isBusiness      Boolean   @default(false)
  // Outstanding credit the customer owes (CREDIT tender / house account).
  creditBalanceCents Int    @default(0)
  visitCount      Int       @default(0)
  lastVisitAt     DateTime?
  optIn           Boolean   @default(true) // marketing opt-in (#125 GDPR)
  orders          Order[]
  creditLedger    CreditLedgerEntry[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("customers")
}

enum CreditEntryType {
  CHARGE  // sale put on the customer's account (CREDIT tender)
  PAYMENT // customer paid down their balance
}

// Full ledger for the customer credit facility (house accounts). Every CREDIT
// sale writes a CHARGE, every settlement writes a PAYMENT with the tender used,
// and balanceAfterCents snapshots the running balance for a printable ledger.
model CreditLedgerEntry {
  id                String          @id @default(cuid())
  customerId        String
  customer          Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type              CreditEntryType
  amountCents       Int
  method            PaymentMethod?  // how a PAYMENT was received (CASH shows in drawer)
  orderId           String?         // the sale behind a CHARGE
  note              String?
  balanceAfterCents Int
  createdBy         String?
  createdAt         DateTime        @default(now())

  @@index([customerId, createdAt])
  @@index([createdAt])
  @@map("credit_ledger_entries")
}

// ─────────────────────────────────────────────────────────────
// FINANCIAL ACCOUNTING & EXPENSES (matrix #156–170)
// ─────────────────────────────────────────────────────────────

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARY
  MARKETING
  MAINTENANCE
  SUPPLIES
  OTHER
}

model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory @default(OTHER)
  amountCents Int
  description String?
  incurredAt  DateTime        @default(now())
  createdAt   DateTime        @default(now())

  @@index([incurredAt])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────
// SPECIALTY COFFEE & ROASTERY (matrix #81–95)
// ─────────────────────────────────────────────────────────────

model GreenBeanBatch {
  id             String   @id @default(cuid())
  name           String   // e.g. "Nepal Everest AA"
  origin         String?
  estate         String?
  process        String?  // Washed / Natural / Honey
  moisturePct    Float?
  weightKg       Float    // received green weight
  remainingKg    Float    // remaining un-roasted
  costPerKgCents Int      @default(0)
  purchasedAt    DateTime @default(now())
  roasts         RoastBatch[]
  cuppings       CuppingScore[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("green_bean_batches")
}

model RoastBatch {
  id              String         @id @default(cuid())
  number          Int            @default(autoincrement())
  greenBatchId    String
  greenBatch      GreenBeanBatch @relation(fields: [greenBatchId], references: [id], onDelete: Cascade)
  greenInputKg    Float
  roastedOutputKg Float
  shrinkagePct    Float          // auto-computed (#83)
  chargeTempC     Float?
  dropTempC       Float?
  devTimeSec      Int?
  agtron          Int?           // roast colour (#93)
  notes           String?
  roastedAt       DateTime       @default(now())

  @@map("roast_batches")
}

model CuppingScore {
  id           String         @id @default(cuid())
  greenBatchId String
  greenBatch   GreenBeanBatch @relation(fields: [greenBatchId], references: [id], onDelete: Cascade)
  aroma        Float
  flavor       Float
  acidity      Float
  body         Float
  balance      Float
  total        Float // sum of the five (out of 50)
  notes        String?
  createdAt    DateTime       @default(now())

  @@map("cupping_scores")
}

// Immutable audit trail of sensitive actions (matrix #155/#08, spec §3.1).
model AuditLog {
  id           String   @id @default(cuid())
  employeeId   String?
  employeeName String
  action       String   // VOID, REFUND, LOGIN, …
  detail       String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@map("audit_logs")
}

model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Nullable so "open items" (custom name/price, not on the menu) are
  // supported (matrix #16).
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])

  // Snapshot of name/price at time of ordering.
  nameSnapshot String
  unitPriceCents Int
  quantity     Int      @default(1)

  // Selected modifiers stored as JSON snapshot: [{name, priceCents}]
  modifiers  Json?
  kotStatus  KotStatus   @default(PENDING)
  station    PrepStation @default(BILLING) // snapshot of the item's prep station
  kotPrintedAt DateTime? // set once a physical KOT/BOT ticket has been printed
  discountCents Int      @default(0) // item-wise discount (needs manager perm)
  notes      String?

  // Item-level cancellation (prints a cancellation KOT + audited).
  cancelledAt  DateTime?
  cancelReason String?
  cancelledBy  String? // approving manager/admin's name, for the cancelled-items report

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("order_items")
}

enum PaymentMethod {
  OFFLINE
  CASH
  FONEPAY
  BANK
  ESEWA
  KHALTI
  CARD
  CREDIT
}

model Payment {
  id         String        @id @default(cuid())
  orderId    String
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountCents Int
  method     PaymentMethod @default(CASH)
  createdAt  DateTime      @default(now())

  @@index([orderId])
  @@index([method, createdAt])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────
// SETTINGS (editable receipt branding — matrix #11)
// ─────────────────────────────────────────────────────────────

model CafeSetting {
  // Single-row table; always addressed by id = "singleton".
  id                String   @id @default("singleton")
  restaurantName    String   @default("CakeZake")
  address           String?
  phone             String?
  taxId             String?  // PAN / VAT registration number
  // Configurable tax rates (matrix #7), stored as fractions (0.13 = 13%).
  vatRate           Float    @default(0.13)
  serviceChargeRate Float    @default(0)
  // When true, menu prices already include VAT (tax is back-calculated).
  pricesIncludeVat  Boolean  @default(false)
  // Dynamic preferences (Settings → Preferences).
  currencySymbol    String   @default("Rs")
  defaultGuestCount Int      @default(1)
  receiptHeader     String?
  receiptFooter     String?
  wifiPassword      String?

  // Printable ticket templates (visual editor under Settings → Printing).
  billTemplate      Json?
  kotTemplate       Json?

  // IRD Nepal (CBMS e-billing) integration.
  irdEnabled   Boolean @default(false)
  irdUsername  String?
  irdPassword  String?
  irdSellerPan String?
  irdApiUrl    String? // e.g. https://cbapi.ird.gov.np/api/bill

  // ZKTeco attendance device on the local network (TCP port 4370).
  zkDeviceIp   String?
  zkDevicePort Int     @default(4370)

  // Module feature toggles — admin enables/disables sections app-wide.
  featReservations Boolean @default(true)
  featInventory    Boolean @default(true)
  featPurchasing   Boolean @default(true)
  featRoastery     Boolean @default(true)
  featModifiers    Boolean @default(true)
  featCrm          Boolean @default(true)
  featFinance      Boolean @default(true)
  featKds          Boolean @default(true)

  updatedAt         DateTime @updatedAt

  @@map("cafe_settings")
}

// Named, reusable discounts (e.g. "Staff 10%", "Regular Rs 100") offered as
// one-tap choices in the POS discount modal instead of typing a number.
model DiscountPreset {
  id        String       @id @default(cuid())
  name      String
  type      DiscountType @default(PCT)
  value     Int          // percentage (whole number) or Rs amount in cents, per `type`
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("discount_presets")
}

enum DiscountType {
  PCT
  RS
}

// ─────────────────────────────────────────────────────────────
// CASH DRAWER (petty-cash flow — matrix #17)
// ─────────────────────────────────────────────────────────────

enum CashMovementType {
  OPENING
  PAY_IN
  PAY_OUT
}

// A physical POS terminal / till (multi-terminal support).
model Terminal {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("terminals")
}

model CashDrawerSession {
  id                String    @id @default(cuid())
  terminalId        String?   // which till this session belongs to
  openedAt          DateTime  @default(now())
  openingFloatCents Int       @default(0)
  openedBy          String?
  closedAt          DateTime?
  closedBy          String?
  countedCents      Int? // physically counted cash at close
  expectedCents     Int? // system-expected cash at close
  varianceCents     Int? // counted - expected
  notes             String?
  movements         CashMovement[]

  @@map("cash_drawer_sessions")
}

model CashMovement {
  id          String            @id @default(cuid())
  sessionId   String
  session     CashDrawerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        CashMovementType
  amountCents Int
  reason      String?
  createdAt   DateTime          @default(now())

  @@index([sessionId])
  @@map("cash_movements")
}

// ─────────────────────────────────────────────────────────────
// INVENTORY & RECIPE (matrix #56–80)
// ─────────────────────────────────────────────────────────────

model Ingredient {
  id           String  @id @default(cuid())
  name         String
  unit         String  @default("g") // base stock unit: g / ml / pcs
  // Global on-hand total across all warehouses — kept in sync with the sum of
  // WarehouseStock rows below; stays authoritative for existing code that
  // doesn't care about location (recipe costing, reorder alerts, etc.).
  stockQty     Float   @default(0)
  reorderLevel Float   @default(0)   // low-stock threshold (#58)
  // Cost per base unit, in cents (paisa) — drives valuation (#75).
  costPerUnitCents Int  @default(0)
  // Primary supplier for reordering (supplier catalog mapping, #67).
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  recipeItems  RecipeItem[]
  movements    StockMovement[]
  poLines      PurchaseOrderLine[]
  warehouseStocks WarehouseStock[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ingredients")
}

// ─────────────────────────────────────────────────────────────
// WAREHOUSES / MULTI-LOCATION STOCK — additive layer on top of the
// existing global Ingredient.stockQty. A restaurant with one location can
// ignore this entirely (everything lives in the seeded "Main Store");
// multi-location operators get a per-warehouse breakdown + transfers.
// ─────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String?
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false) // the auto-seeded "Main Store"; can't be deleted
  stocks    WarehouseStock[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("warehouses")
}

model WarehouseStock {
  id           String     @id @default(cuid())
  warehouseId  String
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  qty          Float      @default(0)

  @@unique([warehouseId, ingredientId])
  @@index([ingredientId])
  @@map("warehouse_stocks")
}

// ─────────────────────────────────────────────────────────────
// PURCHASING & SUPPLIERS (matrix #141–155)
// ─────────────────────────────────────────────────────────────

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contact     String?  // phone / email
  address     String?
  taxId       String?
  isActive    Boolean  @default(true)
  ingredients Ingredient[]
  orders      PurchaseOrder[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  number     Int                 @default(autoincrement())
  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  status     PurchaseOrderStatus @default(DRAFT)
  notes      String?
  lines      PurchaseOrderLine[]
  orderedAt  DateTime?
  receivedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id            String        @id @default(cuid())
  poId          String
  po            PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  ingredientId  String
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])
  quantity      Float         // ordered qty in ingredient unit
  receivedQty   Float         @default(0) // received so far (split delivery #146)
  unitCostCents Int           @default(0)

  @@map("purchase_order_lines")
}

model RecipeItem {
  id           String     @id @default(cuid())
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  // Amount of the ingredient consumed per one menu item (in ingredient.unit).
  quantity     Float

  @@unique([menuItemId, ingredientId])
  @@map("recipe_items")
}

enum StockMovementType {
  PURCHASE
  SALE_DEDUCTION
  WASTAGE
  STOCK_TAKE
  ADJUSTMENT
  TRANSFER
}

model StockMovement {
  id           String            @id @default(cuid())
  ingredientId String
  ingredient   Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  type         StockMovementType
  quantity     Float             // signed delta in base unit (− for consumption)
  reason       String?
  // Which warehouse this movement applies to (null = legacy/global-only
  // movement predating this feature). For TRANSFER, warehouseId is the
  // source (its delta is negative) and toWarehouseId is the destination.
  warehouseId   String?
  toWarehouseId String?
  createdAt    DateTime          @default(now())

  @@index([ingredientId])
  @@index([warehouseId])
  @@map("stock_movements")
}

// Idempotency store — lets the offline outbox safely replay a queued mutation
// without creating duplicates. The client sends a stable Idempotency-Key header;
// the first execution's response is cached and returned verbatim on any replay.
model IdempotencyKey {
  key        String   @id
  method     String
  path       String
  statusCode Int
  response   Json
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@map("idempotency_keys")
}

// ─────────────────────────────────────────────────────────────
// DOUBLE-ENTRY ACCOUNTING (chart of accounts + manual journals)
// ─────────────────────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

// Chart of accounts. System accounts are seeded and undeletable; their ledger
// views also merge live POS activity (cash/bank/sales/VAT/debtors).
model LedgerAccount {
  id        String      @id @default(cuid())
  code      String      @unique // e.g. "1000"
  name      String
  type      AccountType
  group     String?     // e.g. "Current Assets", "Indirect Expenses"
  isSystem  Boolean     @default(false)
  isActive  Boolean     @default(true)
  lines     JournalLine[]
  createdAt DateTime    @default(now())

  @@map("ledger_accounts")
}

// A manual voucher (Journal / Payment / Receipt / Contra). Lines must balance.
model JournalEntry {
  id        String        @id @default(cuid())
  number    Int           @default(autoincrement())
  type      String        @default("JOURNAL")
  date      DateTime      @default(now())
  narration String?
  createdBy String?
  lines     JournalLine[]
  createdAt DateTime      @default(now())

  @@index([date])
  @@map("journal_entries")
}

model JournalLine {
  id        String        @id @default(cuid())
  entryId   String
  entry     JournalEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId String
  account   LedgerAccount @relation(fields: [accountId], references: [id])
  drCents   Int           @default(0)
  crCents   Int           @default(0)

  @@index([accountId])
  @@map("journal_lines")
}


// Fingerprint punches pulled from the ZKTeco device (or added manually).
// (deviceUserId, at) is unique so re-syncing never duplicates records.
model AttendanceLog {
  id           String    @id @default(cuid())
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  deviceUserId String
  at           DateTime
  source       String    @default("DEVICE") // DEVICE | MANUAL
  createdAt    DateTime  @default(now())

  @@unique([deviceUserId, at])
  @@index([employeeId, at])
  @@index([at])
  @@map("attendance_logs")
}

// ─────────────────────────────────────────────────────────────
// SAAS CONTROL PLANE (only meaningful in the platform/control DB)
// Each tenant restaurant gets its OWN PostgreSQL database created from this
// same schema; these tables track tenants, plans and subscription payments.
// ─────────────────────────────────────────────────────────────

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

model Plan {
  id                String   @id @default(cuid())
  code              String   @unique // STARTER | PRO | ENTERPRISE
  name              String
  priceMonthlyCents Int
  priceYearlyCents  Int
  maxEmployees      Int      @default(10)
  maxItems          Int      @default(200)
  features          Json?    // marketing bullet list
  isActive          Boolean  @default(true)
  tenants           Tenant[]
  payments          SubscriptionPayment[]
  createdAt         DateTime @default(now())

  @@map("plans")
}

model Tenant {
  id          String       @id @default(cuid())
  slug        String       @unique // subdomain / x-tenant header value
  name        String
  dbName      String       @unique
  status      TenantStatus @default(TRIAL)
  planId      String?
  plan        Plan?        @relation(fields: [planId], references: [id])
  ownerName   String?
  ownerPhone  String?
  ownerEmail  String?
  trialEndsAt DateTime?
  paidUntil   DateTime?
  notes       String?
  payments    SubscriptionPayment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tenants")
}

// Manual subscription payment gateway: cash at office or direct bank transfer,
// recorded + verified by the platform owner. Verification extends paidUntil.
model SubscriptionPayment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId      String?
  plan        Plan?    @relation(fields: [planId], references: [id])
  amountCents Int
  method      String   // CASH | BANK_TRANSFER
  reference   String?  // bank voucher / txn reference
  months      Int      @default(1)
  status      String   @default("VERIFIED") // PENDING | VERIFIED | REJECTED
  periodStart DateTime
  periodEnd   DateTime
  receivedBy  String?
  note        String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("subscription_payments")
}
